# Git attributes for OpenClaw Skills

# Auto detect text files and perform LF normalization
* text=auto

# Python files
*.py text eol=lf
*.pyx text eol=lf
*.pyd binary

# JavaScript/TypeScript files
*.js text eol=lf
*.mjs text eol=lf
*.ts text eol=lf
*.json text eol=lf

# Markdown files
*.md text eol=lf
*.mdx text eol=lf

# YAML files
*.yml text eol=lf
*.yaml text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Documentation
*.txt text eol=lf
LICENSE text eol=lf

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text

# Archives
*.zip binary
*.tar.gz binary
*.rar binary

# Other binary files
*.pdf binary
*.doc binary
*.docx binary
